{
  "name": "@innbell/www",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "e2e": "playwright test",
    "lint": "oxlint -c ../../packages/config/oxlintrc.json ./src",
    "lint:fix": "yarn lint --fix",
    "preview": "NODE_OPTIONS='-r dotenv/config' yarn start",
    "start": "react-router-serve ./build/server/index.js",
    "format": "prettier --write ./src",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@innbell/blog": "workspace:*",
    "@innbell/components": "workspace:*",
    "@innbell/constants": "workspace:*",
    "@innbell/contexts": "workspace:*",
    "@innbell/editor": "workspace:*",
    "@innbell/emails": "workspace:*",
    "@innbell/leads": "workspace:*",
    "@innbell/reports": "workspace:*",
    "@innbell/root": "workspace:*",
    "@innbell/router": "workspace:*",
    "@innbell/toasts": "workspace:*",
    "@innbell/turnstile": "workspace:*",
    "@innbell/utils": "workspace:*",
    "@react-router/serve": "*",
    "react": "*",
    "react-dom": "*",
    "react-router": "*",
    "remix-utils": "*"
  },
  "devDependencies": {
    "@innbell/config": "workspace:*",
    "@innbell/icons": "workspace:*",
    "@playwright/test": "^1.46.0",
    "@react-router/dev": "*",
    "@react-router/fs-routes": "*",
    "@total-typescript/ts-reset": "^0.5.1",
    "@types/node": "*",
    "@types/react": "*",
    "oxlint": "^0.7.0",
    "postcss": "^8.4.41",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "*",
    "vite": "*"
  }
}
