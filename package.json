{
  "name": "innbell",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "icon": "yarn icon:build; yarn icon:copy",
    "icon:lucide": "yarn workspace @innbell/icons download lucide",
    "icon:simple": "yarn workspace @innbell/icons download simple",
    "icon:build": "yarn workspace @innbell/icons build",
    "icon:copy": "yarn workspace @innbell/icons copy",
    "lint": "turbo lint",
    "routes": "node  --experimental-strip-types ./scripts/gen-routes-path.ts",
    "storybook:dev": "yarn workspace @innbell/components storybook:dev",
    "storybook:build": "yarn workspace @innbell/components storybook:build",
    "storybook:test": "yarn workspace @innbell/components storybook:test",
    "test": "turbo test",
    "build": "turbo build",
    "dev": "turbo dev",
    "e2e": "turbo e2e",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "oxlint": "^0.7.0",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "turbo": "^2.3.1",
    "typescript": "^5.7.0",
    "vite": "^5.3.5",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@4.6.0",
  "resolutions": {
    "react-router": "7.1.1",
    "@react-router/dev": "7.1.1",
    "@react-router/node": "7.1.1",
    "@react-router/serve": "7.1.1",
    "@react-router/fs-routes": "7.1.1",
    "@types/node": "22.1.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remix-utils": "8.0.0",
    "typescript": "^5.7.0",
    "vite": "5.3.5"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss",
      "@ianvs/prettier-plugin-sort-imports"
    ],
    "importOrder": [
      "",
      "^(@innbell|~)(/.*)$",
      "^[.]"
    ]
  },
  "browserslist": {
    "production": [
      ">0.01%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      ">0.01%",
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
