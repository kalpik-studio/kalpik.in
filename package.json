{
  "name": "kalpik.in",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "icon": "node --experimental-strip-types ./scripts/gen-sprite.ts",
    "icon:lucide": "node --experimental-strip-types ./scripts/download-icons.ts lucide",
    "icon:simple": "node --experimental-strip-types ./scripts/download-icons.ts simple",
    "routes": "node  --experimental-strip-types ./scripts/gen-routes-path.ts",
    "build": "react-router build",
    "dev": "react-router dev",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write ./src",
    "preview": "NODE_OPTIONS='-r dotenv/config' yarn start",
    "lint": "oxlint -c ./oxlintrc.json ./src",
    "lint:fix": "yarn lint --fix",
    "start": "react-router-serve ./build/server/index.js"
  },
  "dependencies": {
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@react-router/node": "7.1.1",
    "@react-router/serve": "7.1.1",
    "blurhash": "^2.0.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "csv-parse": "^5.5.6",
    "framer-motion": "^11.3.21",
    "isbot": "^5.1.14",
    "lru-cache": "^11.0.0",
    "markdown-to-jsx": "^7.4.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.1.1",
    "remix-utils": "8.0.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.4.0",
    "ua-parser-js": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@react-router/dev": "7.1.1",
    "@react-router/fs-routes": "7.1.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@total-typescript/ts-reset": "^0.5.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ua-parser-js": "^0.7.39",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "oxlint": "^0.7.0",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.0",
    "vite": "^5.3.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@4.6.0",
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss",
      "@ianvs/prettier-plugin-sort-imports"
    ],
    "importOrder": [
      "",
      "^(@innbell|~)(/.*)$",
      "^[.]"
    ]
  },
  "browserslist": {
    "production": [
      ">0.01%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      ">0.01%",
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
