{
  "name": "@innbell/icons",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "node --experimental-strip-types scripts/gen-sprite.ts",
    "copy": "node --experimental-strip-types scripts/copy-sprite.ts",
    "download": "node --experimental-strip-types scripts/download-icons.ts",
    "lint": "oxlint -c ../../packages/config/oxlintrc.json ./src",
    "lint:fix": "yarn lint --fix --fix-suggestions",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@innbell/config": "workspace:*"
  },
  "exports": {
    "./package.json": "./package.json",
    "./svg/*": "./src/svg/*",
    "./build/*": "./build/*",
    ".": "./src/icons.ts"
  }
}
